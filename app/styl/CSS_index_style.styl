span 
	font-size large
	font-weight bold
.text 
	text-align justify
.menu 
	& > ul 
		list-style none
	a 
		&:hover 
			text-decoration none
img 
	width 100%
	height 100%
	display block
	margin 0 auto
.picture 
	width 250px
	height 150px
	width 100%
	height auto
	margin-top 5px
	img 
		&:hover 
			border 1px solid black
.gallery 
	display flex
	flex-wrap wrap
	justify-content space-evenly
	min-width 280px
.pic 
	display flex
	align-items center
	flex-direction column
	justify-content center
	img 
		width 300px
		vertical-align middle
		width 100%
	& > div 
		&:first-child 
			margin-right 10px
			margin-bottom 5px
